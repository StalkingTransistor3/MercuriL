PORT=3000

# Airtable — Personal Access Token (create at https://airtable.com/create/tokens
# with scopes: data.records:write, schema.bases:read; access limited to the MercuriL base)
AIRTABLE_TOKEN=

# Base ID (starts with "app...") and table name/ID for intake submissions
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Inquiries
